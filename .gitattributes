# Normalize line endings: store everything as LF in the repo, let Git decide
# the working-tree EOL. Stops the "LF will be replaced by CRLF" churn on Windows.
* text=auto eol=lf

# Source and docs — always LF
*.md     text eol=lf
*.cs     text eol=lf
*.csproj text eol=lf
*.props  text eol=lf
*.targets text eol=lf
*.sln    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.py     text eol=lf
*.sh     text eol=lf

# Windows scripts — keep CRLF
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.vsdx   binary
*.nupkg  binary
*.snk    binary
*.pdf    binary
