<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Solution-local NuGet configuration for the UdpCicd .NET solution.

    The machine-wide NuGet.Config applies a restrictive <packageSourceMapping>
    that only whitelists a curated set of packages. This solution needs several
    additional third-party packages (YamlDotNet, Spectre.Console, System.CommandLine,
    JsonSchema.Net, Scriban, ModelContextProtocol, xUnit, ...). Package source
    mapping is read from the *nearest* config file, so this file re-opens
    nuget.org for everything restored under the dotnet/ folder only.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
